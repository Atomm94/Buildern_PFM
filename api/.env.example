PORT=4000

# Root env for docker compose variable substitution
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=pfm_db
MYSQL_USER=pfm
MYSQL_PASSWORD=pfm


DATABASE_URL=mysql://pfm:pfm@127.0.0.1:3307/pfm_db

# JWT secrets — generate with: openssl rand -hex 64
JWT_ACCESS_SECRET=change_me_access_secret
JWT_REFRESH_SECRET=change_me_refresh_secret

ACCESS_TOKEN_EXPIRES=15m
REFRESH_TOKEN_EXPIRES=7d

# allowed CORS origins
WEB_ORIGIN=http://localhost:5173

# Base URL used to build invitation accept links sent via email
WEB_BASE_URL=http://localhost:5173

# SMTP — leave SMTP_HOST blank to log emails to the console (dev/test mode)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM=no-reply@buildern.local

NODE_ENV=development
